<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>MsBuildPipeLogger.Server</id>
    <version>1.1.6</version>
    <authors>Dave Glick and contributors</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://msbuildpipelogger.netlify.com/</projectUrl>
    <description>A logger for MSBuild that sends event data over anonymous or named pipes.</description>
    <repository type="git" url="https://github.com/daveaglick/MsBuildPipeLogger.git" commit="71e6644696cb8826dd53259c2dd690be10d6f00e" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Build" version="15.3.409" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>