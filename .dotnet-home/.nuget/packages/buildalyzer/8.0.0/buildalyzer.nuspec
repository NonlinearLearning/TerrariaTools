<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Buildalyzer</id>
    <version>8.0.0</version>
    <authors>Dave Glick, Pablo Monteiro, Corniel Nobel, and contributors</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/phmonte/Buildalyzer</projectUrl>
    <iconUrl>https://github.com/phmonte/Buildalyzer/blob/main/icon.png</iconUrl>
    <description>A little utility to perform design-time builds of .NET projects without
      having to think too hard about it. Should work with any project type on
      any .NET runtime.</description>
    <releaseNotes>ToBeReleased
- Drop Buildalyzer.EmptyDisposable. (BREAKING)
- Publish SBOM.</releaseNotes>
    <copyright>Dave Glick, Pablo Monteiro</copyright>
    <tags>Roslyn,
      MsBuild,
      Workspaces,
      C#,
      F#,
      VB.NET</tags>
    <repository type="git" url="https://github.com/phmonte/Buildalyzer.git" commit="988347edfae90910f46abaadc1645e238188c64f" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="Buildalyzer.Logger" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="MSBuild.StructuredLogger" version="2.2.158" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Build" version="17.10.4" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Build.Tasks.Core" version="17.10.29" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="4.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.VisualBasic" version="4.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging" version="6.0.0" exclude="Build,Analyzers" />
        <dependency id="MsBuildPipeLogger.Server" version="1.1.6" exclude="Build,Analyzers" />
        <dependency id="NuGet.Frameworks" version="6.9.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="Buildalyzer.Logger" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="MSBuild.StructuredLogger" version="2.2.158" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Build" version="17.10.4" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Build.Tasks.Core" version="17.10.29" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="4.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.VisualBasic" version="4.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging" version="6.0.0" exclude="Build,Analyzers" />
        <dependency id="MsBuildPipeLogger.Server" version="1.1.6" exclude="Build,Analyzers" />
        <dependency id="NuGet.Frameworks" version="6.9.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>